#!/usr/bin/env node
import { execFileSync } from "child_process";
import { ensureBinary, findBinary } from "../download.mjs";

let bin = findBinary();
if (!bin) {
  try {
    bin = await ensureBinary();
  } catch (err) {
    console.error(`flowleap: could not fetch the native binary: ${err.message}`);
    console.error("Retry, or download it manually from https://github.com/abdullahatrash/flowleap-cli/releases");
    process.exit(1);
  }
}

try {
  execFileSync(bin, process.argv.slice(2), { stdio: "inherit", argv0: "flowleap" });
} catch (err) {
  process.exit(err.status ?? 1);
}
